SECRET_KEY=your_jwt_secret_key_here

# Gmail SMTP settings for OTP emails
# Use your Gmail address and an App Password (not your regular password)
# To get an App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=*/enter port/*
SMTP_USER=*/enter your mail/*
SMTP_PASS=*/enter your smtp pass/*
